{
  "name": "payload-client-query",
  "version": "0.1.0",
  "description": "Type-safe client for querying Payload CMS from frontend components",
  "author": "Bob Bass <bob@layerbase.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertjbass/payload-client-query.git"
  },
  "keywords": [
    "payload",
    "payloadcms",
    "typescript",
    "client",
    "query",
    "rest",
    "type-safe",
    "frontend"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.test.json"
  },
  "peerDependencies": {
    "payload": ">=3.0.0"
  },
  "devDependencies": {
    "prettier": "^3.5.0",
    "typescript": "^5.9.0"
  }
}
